@baseUrl = http://localhost:8080
@workflowId = flow-merge-workflow

### 1. MERGE 노드 중심 워크플로우 저장
POST {{baseUrl}}/api/workflows
Content-Type: application/json

{
  "id": "{{workflowId}}",
  "name": "Merge Flow Runtime Test",
  "version": 1,
  "nodes": [
    {
      "id": "node_start",
      "name": "Start",
      "type": "START",
      "params": {}
    },
    {
      "id": "node_http_a",
      "name": "HTTP A",
      "type": "HTTP",
      "params": {
        "url": "https://api.example.com/orders/<<request.id>>"
      }
    },
    {
      "id": "node_http_b",
      "name": "HTTP B",
      "type": "HTTP",
      "params": {
        "url": "https://api.example.com/customers/<<customerId>>"
      }
    },
    {
      "id": "node_http_c",
      "name": "HTTP C",
      "type": "HTTP",
      "params": {
        "url": "https://api.example.com/payments/<<paymentId>>"
      }
    },
    {
      "id": "node_merge",
      "name": "Merge",
      "type": "MERGE",
      "params": {}
    }
  ],
  "connections": {
    "node_start": {
      "main": [
        [
          {
            "nodeId": "node_http_a",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "node_http_a": {
      "main": [
        [
          {
            "nodeId": "node_http_b",
            "type": "main",
            "index": 0
          },
          {
            "nodeId": "node_http_c",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "node_http_b": {
      "main": [
        [
          {
            "nodeId": "node_merge",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "node_http_c": {
      "main": [
        [
          {
            "nodeId": "node_merge",
            "type": "main",
            "index": 1
          }
        ]
      ]
    }
  }
}

### 2. 워크플로우 실행 시작
POST {{baseUrl}}/api/executions/{{workflowId}}/start
Content-Type: application/json

{
  "request": {
    "id": "merge-001"
  },
  "customerId": "customer-1",
  "paymentId": "payment-1"
}

> {% client.global.set("mergeExecutionId", response.body.executionId); %}

### 3. 실행 상태 조회
GET {{baseUrl}}/api/executions/{{mergeExecutionId}}

### 4. 노드 실행 이력 조회
GET {{baseUrl}}/api/executions/{{mergeExecutionId}}/nodes
