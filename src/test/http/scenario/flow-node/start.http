@baseUrl = http://localhost:8080
@workflowId = flow-start-workflow

### 1. START 노드 중심 워크플로우 저장
POST {{baseUrl}}/api/workflows
Content-Type: application/json

{
  "id": "{{workflowId}}",
  "name": "Start Flow Runtime Test",
  "version": 1,
  "nodes": [
    {
      "id": "node_start",
      "name": "Start",
      "type": "START",
      "params": {}
    },
    {
      "id": "node_test",
      "name": "After Start",
      "type": "END",
      "params": {
        "name": "Started by <<request.id>>"
      }
    }
  ],
  "connections": {
    "node_start": {
      "main": [
        [
          {
            "nodeId": "node_test",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}

### 2. 워크플로우 실행 시작
POST {{baseUrl}}/api/executions/{{workflowId}}/start
Content-Type: application/json

{
  "request": {
    "id": "start-001"
  }
}

> {% client.global.set("startExecutionId", response.body.executionId); %}

### 3. 실행 상태 조회
GET {{baseUrl}}/api/executions/{{startExecutionId}}

### 4. 노드 실행 이력 조회
GET {{baseUrl}}/api/executions/{{startExecutionId}}/nodes
